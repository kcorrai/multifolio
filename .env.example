# Multifolio ortam değişkenleri — ŞABLON.
# Bu dosyayı `.env.local` olarak kopyala ve gerçek değerleri gir.
# .env.local ASLA commit edilmez (.gitignore). Sırlar yalnızca sunucuda kalır.

# --- Supabase ---
# Public (tarayıcıya gidebilir): proje URL'i ve ANON anahtarı. RLS bunları güvenli kılar.
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
# GİZLİ: service-role RLS'i bypass eder. NEXT_PUBLIC_ DEĞİL; asla istemciye sızdırma.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# --- Sentry ---
# DSN public'tir (tarayıcı hata gönderir). Boşsa Sentry no-op çalışır.
NEXT_PUBLIC_SENTRY_DSN=""
# Source map yüklemesi için (yalnızca CI/üretim build'i). GİZLİ.
SENTRY_AUTH_TOKEN=""
SENTRY_ORG=""
SENTRY_PROJECT=""

# --- Anthropic Claude (uyarlama motoru, Faz 1) ---
# GİZLİ: yalnızca sunucuda kullanılır.
ANTHROPIC_API_KEY=""

# --- Alt-proje B scraper ---
# GİZLİ: internal /api/internal/scrape route'unu koruyan cron sırrı.
# Dış cron (cron-job.org) bu değeri x-cron-secret header'ında gönderir.
SCRAPER_CRON_SECRET=""

# --- Herkese açık /analyze aracı ---
# GİZLİ: kayıtsız isteklerin IP hash'lemesinde tuz (ham IP saklanmaz).
# Boşsa SUPABASE_SERVICE_ROLE_KEY'den türetilir — ayrı değer önerilir.
ANALYZE_IP_SALT=""
