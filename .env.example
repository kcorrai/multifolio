# Multifolio ortam değişkenleri — ŞABLON.
# Bu dosyayı `.env.local` olarak kopyala ve gerçek değerleri gir.
# .env.local ASLA commit edilmez (.gitignore). Sırlar yalnızca sunucuda kalır.

# --- Supabase ---
# Public (tarayıcıya gidebilir): proje URL'i ve ANON anahtarı. RLS bunları güvenli kılar.
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
# GİZLİ: service-role RLS'i bypass eder. NEXT_PUBLIC_ DEĞİL; asla istemciye sızdırma.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# --- Sentry ---
# DSN public'tir (tarayıcı hata gönderir). Boşsa Sentry no-op çalışır.
NEXT_PUBLIC_SENTRY_DSN=""
# Source map yüklemesi için (yalnızca CI/üretim build'i). GİZLİ.
SENTRY_AUTH_TOKEN=""
SENTRY_ORG=""
SENTRY_PROJECT=""

# --- OpenAI (uyarlama motoru — gpt-4o-mini) ---
# GİZLİ: yalnızca sunucuda kullanılır.
OPENAI_API_KEY=""

# --- Resend (uygulama bildirim e-postaları — Resend HTTP API) ---
# GİZLİ: RESEND_SMTP_PASS = Resend API anahtarı (bearer). Boşsa e-posta no-op.
# NOT: Supabase Auth e-postaları AYRI (Supabase panelinde Custom SMTP).
RESEND_SMTP_PASS=""
# Gönderen adresi: Resend'de DOĞRULANMIŞ domain olmalı; yoksa onboarding@resend.dev'e düşer
# (yalnız Resend hesabının kendi adresine gönderir → gerçek kullanıcıya gitmez).
RESEND_FROM_EMAIL=""

# --- Alt-proje B scraper ---
# GİZLİ: internal /api/internal/scrape route'unu koruyan cron sırrı.
# Dış cron (cron-job.org) bu değeri x-cron-secret header'ında gönderir.
SCRAPER_CRON_SECRET=""

# --- Admin paneli ---
# Virgülle ayrılmış admin e-postaları; /admin bu allowlist'e açık (aksi → 404).
# NEXT_PUBLIC_ DEĞİL → istemciye sızmaz. Boşsa admin YOK (panel kimseye açılmaz).
# Prod'da Vercel env'ine de eklenmeli (yoksa canlıda admin olmaz).
ADMIN_EMAILS=""

# --- Herkese açık /analyze aracı ---
# GİZLİ: kayıtsız isteklerin IP hash'lemesinde tuz (ham IP saklanmaz).
# Boşsa SUPABASE_SERVICE_ROLE_KEY'den türetilir — ayrı değer önerilir.
ANALYZE_IP_SALT=""

# --- Iyzico ödeme (kredi satın alma — Checkout Form) ---
# GİZLİ: iyzico merchant API anahtar/secret'ı. İkisi de tanımlıysa gerçek checkout
# açılır (pricing'de "Satın Al"); boşsa UI "yakında" gösterir. Sunucu-only.
IYZICO_API_KEY=""
IYZICO_SECRET_KEY=""
# Ortam: sandbox (test) → https://sandbox-api.iyzipay.com (varsayılan);
# prod → https://api.iyzipay.com. Sandbox anahtarları iyzico panelinden alınır.
IYZICO_BASE_URL="https://sandbox-api.iyzipay.com"

# Uygulamanın mutlak taban URL'i (iyzico callback + dönüş yönlendirmesi için).
# Prod'da ZORUNLU (ör. https://multifolio-ecru.vercel.app); boşsa proxy header'larından
# türetilir. iyzico callback için geçerli HTTPS gerekir.
NEXT_PUBLIC_APP_URL=""
