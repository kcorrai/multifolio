{
  "manifest_version": 3,
  "name": "Multifolio Profile Importer",
  "version": "0.1.0",
  "description": "Import your Upwork or Fiverr profile into Multifolio with one click.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": { "service_worker": "background.js" },
  "host_permissions": [
    "https://multifolio-ecru.vercel.app/*",
    "http://localhost:3000/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.upwork.com/freelancers/*",
        "https://www.upwork.com/fl/*",
        "https://www.fiverr.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": { "default_title": "Multifolio" }
}
